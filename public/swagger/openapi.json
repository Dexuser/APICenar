{
  "openapi": "3.0.3",
  "info": {
    "title": "ApiCenar API",
    "version": "1.0.0",
    "description": "Compact OpenAPI documentation for the ApiCenar REST API."
  },
"servers": [
  {
    "url": "https://apicenar-production-cd8f.up.railway.app"
  },
  {
    "url": "http://localhost:5000"
  }
],
  "security": [{ "BearerAuth": [] }],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "GenericObject": {
        "type": "object",
        "additionalProperties": true
      },
      "AuthLogin": {
        "type": "object",
        "required": ["userNameOrEmail", "password"],
        "properties": {
          "userNameOrEmail": { "type": "string" },
          "password": { "type": "string" }
        }
      },
      "AuthRegisterClient": {
        "type": "object",
        "required": ["firstName", "lastName", "userName", "email", "phone", "password", "confirmPassword"],
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "userName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "password": { "type": "string" },
          "confirmPassword": { "type": "string" },
          "profileImage": { "type": "string", "format": "binary" }
        }
      },
      "AuthRegisterDelivery": {
        "type": "object",
        "required": ["firstName", "lastName", "userName", "email", "phone", "password", "confirmPassword"],
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "userName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "password": { "type": "string" },
          "confirmPassword": { "type": "string" },
          "profileImage": { "type": "string", "format": "binary" }
        }
      },
      "AuthRegisterCommerce": {
        "type": "object",
        "required": ["userName", "email", "password", "confirmPassword", "name", "description", "phone", "openingTime", "closingTime", "commerceTypeId", "logo"],
        "properties": {
          "userName": { "type": "string" },
          "description": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" },
          "confirmPassword": { "type": "string" },
          "name": { "type": "string" },
          "phone": { "type": "string" },
          "openingTime": {
            "type": "string",
            "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
          },
          "closingTime": {
            "type": "string",
            "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
          },
          "commerceTypeId": { "type": "string" },
          "logo": { "type": "string", "format": "binary" }
        }
      },
      "AuthConfirmEmail": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": { "type": "string" }
        }
      },
      "AuthForgotPassword": {
        "type": "object",
        "required": ["userNameOrEmail"],
        "properties": {
          "userNameOrEmail": { "type": "string" }
        }
      },
      "AuthResetPassword": {
        "type": "object",
        "required": ["token", "password", "confirmPassword"],
        "properties": {
          "token": { "type": "string" },
          "password": { "type": "string" },
          "confirmPassword": { "type": "string" }
        }
      },
      "AccountUpdateProfile": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "phone": { "type": "string" },
          "openingTime": {
            "type": "string",
            "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
          },
          "closingTime": {
            "type": "string",
            "pattern": "^([01]\\d|2[0-3]):([0-5]\\d)$"
          },
          "profileImage": { "type": "string", "format": "binary" },
          "logo": { "type": "string", "format": "binary" }
        }
      },
      "AddressBody": {
        "type": "object",
        "required": ["label", "street", "sector", "city", "reference"],
        "properties": {
          "label": { "type": "string" },
          "street": { "type": "string" },
          "sector": { "type": "string" },
          "city": { "type": "string" },
          "reference": { "type": "string" }
        }
      },
      "FavoriteBody": {
        "type": "object",
        "required": ["commerceId"],
        "properties": {
          "commerceId": { "type": "string" }
        }
      },
      "CategoryBody": {
        "type": "object",
        "required": ["name", "description"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" }
        }
      },
      "ProductBody": {
        "type": "object",
        "required": ["name", "description", "price", "categoryId"],
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "price": { "type": "number" },
          "categoryId": { "type": "string" },
          "image": { "type": "string", "format": "binary" }
        }
      },
      "OrderItem": {
        "type": "object",
        "required": ["productId", "quantity"],
        "properties": {
          "productId": { "type": "string" },
          "quantity": { "type": "integer", "minimum": 1 }
        }
      },
      "OrderBody": {
        "type": "object",
        "required": ["addressId", "items"],
        "properties": {
          "addressId": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/OrderItem" },
            "minItems": 1
          }
        }
      },
      "ConfigurationUpdateBody": {
        "type": "object",
        "required": ["key", "value"],
        "properties": {
          "key": { "type": "string" },
          "value": { "type": "string" }
        }
      },
      "AdminUserCreateBody": {
        "type": "object",
        "required": ["firstName", "lastName", "userName", "email", "phone", "password", "confirmPassword"],
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "userName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "password": { "type": "string" },
          "confirmPassword": { "type": "string" }
        }
      },
      "AdminUserUpdateBody": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "userName": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": { "type": "string" },
          "password": { "type": "string" },
          "confirmPassword": { "type": "string" }
        }
      },
      "AdminUserStatusBody": {
        "type": "object",
        "required": ["isActive"],
        "properties": {
          "isActive": { "type": "boolean" }
        }
      },
      "CommerceTypeBody": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "icon": { "type": "string", "format": "binary" }
        }
      }
    },
    "parameters": {
      "IdPath": {
        "name": "id",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "CommerceIdPath": {
        "name": "commerceId",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "KeyPath": {
        "name": "key",
        "in": "path",
        "required": true,
        "schema": { "type": "string" }
      },
      "Page": {
        "name": "page",
        "in": "query",
        "description": "Page number for pagination (default 1)",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      },
      "PageSize": {
        "name": "pageSize",
        "in": "query",
        "description": "Number of items per page for pagination (default 10, max 100)",
        "required": false,
        "schema": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        }
      },
      "SortByCommerceTypes": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort commerce types by (title, createdAt, updatedAt, or name)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["title", "createdAt", "updatedAt", "name"],
          "default": "title"
        }
      },
      "SortDirection": {
        "name": "sortDirection",
        "in": "query",
        "description": "Sort direction for results (asc or desc)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["asc", "desc"],
          "default": "asc"
        }
      },
      "Search": {
        "name": "search",
        "in": "query",
        "description": "Search term to filter results by name or title",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "CommerceTypeId": {
        "name": "commerceTypeId",
        "in": "query",
        "description": "Commerce type id used to filter commerces",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "CategoryId": {
        "name": "categoryId",
        "in": "query",
        "description": "Category id used to filter products",
        "required": false,
        "schema": {
          "type": "string"
        }
      },
      "SortByCommerces": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort commerces by (commerceName, createdAt, updatedAt, openTime, closeTime, name, openingTime, closingTime)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["commerceName", "createdAt", "updatedAt", "openTime", "closeTime", "name", "openingTime", "closingTime"],
          "default": "commerceName"
        }
      },
      "SortByProducts": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort products by (createdAt, updatedAt, name, price)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["createdAt", "updatedAt", "name", "price"],
          "default": "createdAt"
        }
      },
      "SortByCategories": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort categories by (createdAt, updatedAt, name)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["createdAt", "updatedAt", "name"],
          "default": "createdAt"
        }
      },
      "SortByClients": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort clients by (createdAt, updatedAt, firstName, lastName, email, isActive)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["createdAt", "updatedAt", "firstName", "lastName", "email", "isActive"],
          "default": "createdAt"
        }
      },
      "SortByDeliveries": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort deliveries by (createdAt, updatedAt, firstName, lastName, email, isActive)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["createdAt", "updatedAt", "firstName", "lastName", "email", "isActive"],
          "default": "createdAt"
        }
      },
      "SortByAdmins": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort administrators by (createdAt, updatedAt, firstName, lastName, username, email, isActive)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["createdAt", "updatedAt", "firstName", "lastName", "username", "email", "isActive"],
          "default": "createdAt"
        }
      },
      "SortByOrders": {
        "name": "sortBy",
        "in": "query",
        "description": "Field to sort orders by (createdAt, updatedAt, total, status)",
        "required": false,
        "schema": {
          "type": "string",
          "enum": ["createdAt", "updatedAt", "total", "status"],
          "default": "createdAt"
        }
      }
    }
  },
